#!/usr/bin/env node
/**
 * Style Pack Generator
 * Inputs:
 *   - style/style.json (required)
 *   - style/index.json (optional; will generate if missing)
 *   - style/fingerprint.json (optional; will validate)
 *   - modules/**/*.md (optional; inventory only)
 *   - tests/golden_prompts.md (optional; will normalize & re-emit)
 *
 * Outputs:
 *   - shoegaze.bundle.json
 *   - style/index.json (generated if missing or --force-index)
 *   - dist/README.generated.md
 *   - dist/golden_prompts.generated.md
 *   - dist/report.json
 */

import fs from "fs";
import path from "path";

const ROOT = process.cwd();

function readText(p) {
  return fs.readFileSync(p, "utf8");
}
function writeText(p, s) {
  fs.mkdirSync(path.dirname(p), { recursive: true });
  fs.writeFileSync(p, s, "utf8");
}
function writeJson(p, obj) {
  fs.mkdirSync(path.dirname(p), { recursive: true });
  fs.writeFileSync(p, JSON.stringify(obj, null, 2) + "\n", "utf8");
}
function exists(p) {
  return fs.existsSync(p);
}

function listFilesRecursive(dir, exts = null) {
  if (!exists(dir)) return [];
  const out = [];
  for (const ent of fs.readdirSync(dir, { withFileTypes: true })) {
    const full = path.join(dir, ent.name);
    if (ent.isDirectory()) out.push(...listFilesRecursive(full, exts));
    else {
      if (!exts) out.push(full);
      else if (exts.includes(path.extname(ent.name).toLowerCase())) out.push(full);
    }
  }
  return out;
}

function normalizeToken(t) {
  return (t || "").trim().replace(/\s+/g, " ");
}

function dedupeTokens(tokens) {
  const seen = new Set();
  const out = [];
  for (let t of tokens) {
    t = normalizeToken(t);
    if (!t) continue;
    const key = t.toLowerCase();
    if (seen.has(key)) continue;
    seen.add(key);
    out.push(t);
  }
  return out;
}

function parseGoldenPrompts(md) {
  // Very simple parser:
  // Sections separated by headings starting with "## " and blocks of text after.
  // We’ll just keep raw blocks, and normalize whitespace.
  const lines = md.split(/\r?\n/);
  const items = [];
  let currentTitle = null;
  let buf = [];
  const flush = () => {
    if (currentTitle && buf.join("\n").trim()) {
      items.push({ title: currentTitle, text: buf.join("\n").trim() });
    }
    buf = [];
  };

  for (const line of lines) {
    const m = line.match(/^##\s+(.*)\s*$/);
    if (m) {
      flush();
      currentTitle = m[1].trim();
      continue;
    }
    if (currentTitle) buf.push(line);
  }
  flush();
  return items;
}

function normalizePromptText(text) {
  // Normalize commas/spaces a bit without changing meaning too aggressively
  // Keep line breaks but remove double spaces.
  return text
    .split(/\r?\n/)
    .map((l) => l.replace(/\s+/g, " ").trimEnd())
    .join("\n")
    .trim();
}

function compileSamplePrompt(style, { subject, presetName }) {
  const cfg = presetName ? style.presets?.[presetName] : style.defaults;
  const enabledBlocks = cfg?.enabledBlocks ?? style.defaults?.enabledBlocks ?? [];
  const parts = [];
  if (subject) parts.push(subject);

  for (const b of enabledBlocks) {
    const block = style.blocks?.[b];
    if (Array.isArray(block)) parts.push(...block);
  }

  const pal = cfg?.palette;
  if (pal) {
    const fmt = style.compiler?.paletteFormat ?? "palette:{palette}";
    parts.push(fmt.replace("{palette}", pal));
  }

  const joiner = style.compiler?.joiner ?? ", ";
  let prompt = parts.join(joiner);

  const negatives = dedupeTokens(style.negatives ?? []);
  if (negatives.length) {
    const negPrefix = style.compiler?.negativePrefix ?? "--no ";
    prompt += ` ${negPrefix}${negatives.join(", ")}`;
  }
  return prompt;
}

function buildIndex(style, entrypoints) {
  const tags = Array.isArray(style.tags) ? style.tags : [];
  const engines = style.engines ? Object.keys(style.engines) : [];
  return {
    id: style.id,
    name: style.name,
    version: style.version,
    category: "atmosphere/texture",
    tags: dedupeTokens(tags.concat(engines.includes("sound_as_image") ? ["sound-as-image", "spectral"] : [])),
    entrypoints,
    compatibility: {
      promptEngines: ["generic", "midjourney", "sdxl", "flux"],
      shaderEngines: ["glsl", "webgl", "threejs", "touchdesigner"],
      requires: ["blocks", "negatives", "presets", "compiler"]
    }
  };
}

function validateFingerprint(style, fingerprint) {
  const allTokens = [];
  for (const k of Object.keys(style.blocks || {})) {
    const block = style.blocks[k];
    if (Array.isArray(block)) allTokens.push(...block);
  }
  allTokens.push(...(style.negatives || []));
  const set = new Set(allTokens.map((t) => normalizeToken(t).toLowerCase()));

  const missingMustHave = [];
  for (const t of fingerprint.must_have_tokens || []) {
    if (!set.has(normalizeToken(t).toLowerCase())) missingMustHave.push(t);
  }
  const presentMustAvoid = [];
  for (const t of fingerprint.must_avoid_tokens || []) {
    if (set.has(normalizeToken(t).toLowerCase())) presentMustAvoid.push(t);
  }
  return { missingMustHave, presentMustAvoid };
}

function generateReadme(style, modulesInventory, enginesInventory) {
  const blockNames = Object.keys(style.blocks || {});
  const presetNames = Object.keys(style.presets || {});
  const paletteNames = style.palettes ? Object.keys(style.palettes) : [];

  const engineNames = enginesInventory.length ? enginesInventory : (style.engines ? Object.keys(style.engines) : []);

  return `# ${style.name} Style Pack (generated)

Version: \`${style.version}\`
ID: \`${style.id}\`

${style.description || ""}

## Quick start
Pick a preset + subject and compile.

Example (gentle):
\`${compileSamplePrompt(style, { subject: "a portrait implied by harmonic ladders", presetName: "gentle_gaze" })}\`

Example (total wall):
\`${compileSamplePrompt(style, { subject: "silhouette implied by beat-frequency interference", presetName: "total_wall" })}\`

## Blocks
${blockNames.map((b) => `- \`${b}\` (${(style.blocks?.[b]?.length ?? 0)} tokens)`).join("\n")}

## Presets
${presetNames.map((p) => `- \`${p}\`${style.presets[p]?.palette ? ` (palette: \`${style.presets[p].palette}\`)` : ""}`).join("\n")}

## Palettes
${paletteNames.length ? paletteNames.map((p) => `- \`${p}\``).join("\n") : "- (none)"}

## Engines
${engineNames.length ? engineNames.map((e) => `- \`${e}\``).join("\n") : "- (none)"}

## Module inventory
Found ${modulesInventory.length} module file(s).

`;
}

function main() {
  const args = process.argv.slice(2);
  const forceIndex = args.includes("--force-index");

  const stylePath = path.join(ROOT, "style", "style.json");
  if (!exists(stylePath)) {
    console.error("Missing required file: style/style.json");
    process.exit(1);
  }

  const style = JSON.parse(readText(stylePath));

  // Normalize core arrays
  style.negatives = dedupeTokens(style.negatives || []);
  for (const k of Object.keys(style.blocks || {})) {
    if (Array.isArray(style.blocks[k])) style.blocks[k] = dedupeTokens(style.blocks[k]);
  }

  // Inventory modules
  const modulesDir = path.join(ROOT, "modules");
  const moduleFiles = listFilesRecursive(modulesDir, [".md", ".txt"]);
  const modulesInventory = moduleFiles.map((f) => path.relative(ROOT, f));

  // Engines inventory (optional)
  const engines = style.engines ? Object.keys(style.engines) : [];
  const enginesInventory = engines;

  // Golden prompts
  const goldenIn = path.join(ROOT, "tests", "golden_prompts.md");
  let goldenItems = [];
  if (exists(goldenIn)) {
    const md = readText(goldenIn);
    goldenItems = parseGoldenPrompts(md).map((it) => ({
      title: it.title,
      text: normalizePromptText(it.text)
    }));
  }

  // Fingerprint validation
  const fpPath = path.join(ROOT, "style", "fingerprint.json");
  let fingerprintReport = null;
  if (exists(fpPath)) {
    const fp = JSON.parse(readText(fpPath));
    fingerprintReport = validateFingerprint(style, fp);
  }

  // Ensure/Generate style/index.json
  const entrypoints = {
    style: "style/style.json",
    mappings: "docs/audio_to_visual_mappings.md",
    quickstart: "recipes/quickstart_25.md",
    soundSeeds: "recipes/sound_as_image_40.md",
    compilerJS: "tools/compile_prompt.js",
    compilerPY: "tools/compile_prompt.py"
  };

  const indexPath = path.join(ROOT, "style", "index.json");
  if (forceIndex || !exists(indexPath)) {
    const idx = buildIndex(style, entrypoints);
    writeJson(indexPath, idx);
  }

  // Bundle build
  const bundle = {
    bundleVersion: "1.0",
    generatedAt: new Date().toISOString(),
    style,
    index: exists(indexPath) ? JSON.parse(readText(indexPath)) : buildIndex(style, entrypoints),
    fingerprint: exists(fpPath) ? JSON.parse(readText(fpPath)) : null,
    inventories: {
      modules: modulesInventory,
      engines: enginesInventory
    }
  };
  writeJson(path.join(ROOT, "shoegaze.bundle.json"), bundle);

  // Generated docs
  writeText(path.join(ROOT, "dist", "README.generated.md"), generateReadme(style, modulesInventory, enginesInventory));

  // Generated golden prompts
  if (goldenItems.length) {
    const out = [
      "# Golden Prompts (generated)",
      "",
      "These are normalized from `tests/golden_prompts.md`.",
      ""
    ];
    for (const it of goldenItems) {
      out.push(`## ${it.title}`, "", it.text, "");
    }
    writeText(path.join(ROOT, "dist", "golden_prompts.generated.md"), out.join("\n"));
  } else {
    writeText(
      path.join(ROOT, "dist", "golden_prompts.generated.md"),
      "# Golden Prompts (generated)\n\nNo `tests/golden_prompts.md` found.\n"
    );
  }

  // Report
  const report = {
    ok: true,
    style: { id: style.id, name: style.name, version: style.version },
    counts: {
      blocks: Object.keys(style.blocks || {}).length,
      presets: Object.keys(style.presets || {}).length,
      palettes: Object.keys(style.palettes || {}).length,
      negatives: (style.negatives || []).length,
      modulesFound: modulesInventory.length,
      goldenPromptsFound: goldenItems.length
    },
    fingerprint: fingerprintReport,
    outputs: [
      "shoegaze.bundle.json",
      "style/index.json",
      "dist/README.generated.md",
      "dist/golden_prompts.generated.md",
      "dist/report.json"
    ],
    notes: [
      "Run with `node tools/generate_stylepack.js`",
      "Use `--force-index` to regenerate style/index.json"
    ]
  };
  writeJson(path.join(ROOT, "dist", "report.json"), report);

  console.log("Generated style pack:");
  for (const o of report.outputs) console.log(" -", o);
  if (fingerprintReport) {
    if (fingerprintReport.missingMustHave.length) {
      console.warn("Fingerprint missing must-have tokens:", fingerprintReport.missingMustHave);
    }
    if (fingerprintReport.presentMustAvoid.length) {
      console.warn("Fingerprint contains must-avoid tokens:", fingerprintReport.presentMustAvoid);
    }
  }
}

main();


