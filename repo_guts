# Audio → Visual Mappings (Shoegaze Sound-as-Image)

Use these rules to translate any sound description into visuals.

## Core mappings
- Pitch → vertical position (high = high)
- Loudness → brightness / bloom intensity
- Timbre brightness (spectral centroid) → edge sharpness / sparkle
- Noise amount → grain density / fog thickness
- Harmonicity → clean banding vs smeared clouds
- Transients → thin vertical streaks / needle highlights
- Reverb → ghost trails / depth haze / temporal smear
- Distortion → texture thickness + edge fuzz + interference shimmer
- Chorus/flange/phaser → phase drift ripples + moiré shimmer
- Compression → flattened contrast + “pumped” glow rhythm

## Shoegaze glue (always-on)
- soften boundaries
- add memory materials (film/paper/signal)
- keep math inside haze (not infographic)

Why it matters: your Copilot agent (and future you) can generate new engines just by following this.

2) A small “Prompt Compiler” reference implementation (JS + Python)
Even if you don’t use it directly, it makes the repo executable.
Create tools/compile_prompt.js
import fs from "fs";

const style = JSON.parse(fs.readFileSync("style/style.json", "utf8"));

function compilePrompt({ subject, preset = null, enabledBlocks = null, palette = null, includeInterference = null }) {
  const cfg = preset ? style.presets[preset] : style.defaults;
  const blocks = enabledBlocks ?? cfg.enabledBlocks ?? style.defaults.enabledBlocks;

  let parts = [];
  if (subject) parts.push(subject);

  // Allow optional interference toggle
  const finalBlocks = [...blocks];
  const wantsInterference =
    includeInterference === true ||
    (includeInterference === null && cfg.enabledBlocks?.includes("interference"));

  if (wantsInterference && !finalBlocks.includes("interference") && style.blocks.interference) {
    finalBlocks.push("interference");
  }

  for (const b of finalBlocks) {
    const block = style.blocks[b];
    if (Array.isArray(block)) parts.push(...block);
  }

  const pal = palette ?? cfg.palette;
  if (pal) parts.push(style.compiler?.paletteFormat?.replace("{palette}", pal) ?? `palette:${pal}`);

  const prompt = parts.join(style.compiler?.joiner ?? ", ");
  const neg = (style.negatives || []).join(", ");
  const negativePrefix = style.compiler?.negativePrefix ?? "--no ";
  return neg.length ? `${prompt} ${negativePrefix}${neg}` : prompt;
}

// Example usage:
console.log(compilePrompt({ subject: "silhouette implied by beat-frequency interference", preset: "total_wall" }));

Create tools/compile_prompt.py
import json

with open("style/style.json", "r", encoding="utf-8") as f:
    style = json.load(f)

def compile_prompt(subject, preset=None, enabled_blocks=None, palette=None, include_interference=None):
    cfg = style["presets"][preset] if preset else style["defaults"]
    blocks = enabled_blocks or cfg.get("enabledBlocks") or style["defaults"]["enabledBlocks"]

    parts = []
    if subject:
        parts.append(subject)

    final_blocks = list(blocks)
    wants_interference = (
        include_interference is True
        or (include_interference is None and "interference" in cfg.get("enabledBlocks", []))
    )
    if wants_interference and "interference" not in final_blocks and "interference" in style["blocks"]:
        final_blocks.append("interference")

    for b in final_blocks:
        block = style["blocks"].get(b)
        if isinstance(block, list):
            parts.extend(block)

    pal = palette or cfg.get("palette")
    if pal:
        fmt = style.get("compiler", {}).get("paletteFormat", "palette:{palette}")
        parts.append(fmt.replace("{palette}", pal))

    joiner = style.get("compiler", {}).get("joiner", ", ")
    prompt = joiner.join(parts)

    neg = ", ".join(style.get("negatives", []))
    neg_prefix = style.get("compiler", {}).get("negativePrefix", "--no ")
    return f"{prompt} {neg_prefix}{neg}" if neg else prompt

if __name__ == "__main__":
    print(compile_prompt("a face implied by harmonic ladders", preset="gentle_gaze"))

